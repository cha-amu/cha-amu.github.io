# Public frontend config only. Do not put secrets here.
VITE_APPS_SCRIPT_URL=https://script.google.com/macros/s/AKfycbwn-qQpt3j2bxyzNtQeKSodJdo0Apvust80TPAxlp7U0jg2bZ0GI0FoJF3c4ZOTnQjt/exec
VITE_STORAGE_BASE_URL=https://cha-amu.github.io/storage
VITE_ARCHIVE_MANIFEST_URL=https://cha-amu.github.io/storage/manifests/assets.json
VITE_STORAGE_POSTS_MANIFEST_URL=https://cha-amu.github.io/storage/manifests/posts.json
VITE_TURNSTILE_SITE_KEY=
# Test default is 1 minute. Production can be 36000000 for 10 hours.
VITE_ADMIN_IDLE_TIMEOUT_MS=60000

# Server-side Apps Script input. Real value only in local .env.
# 직접 입력할 값은 ADMIN_PASSWORD 하나뿐이다. Never expose it with VITE_ prefix.
SPREADSHEET_ID=<SPREADSHEET_ID>
ADMIN_PASSWORD=
GUESTBOOK_PASSWORD_ITERATIONS=1
ADMIN_SESSION_TTL_MS=60000
TURNSTILE_SECRET_KEY=
